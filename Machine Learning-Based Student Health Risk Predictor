      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "from sklearn.tree import DecisionTreeClassifier\n",
        "\n",
        "data = {\n",
        "    'Sleep': [4, 6, 8, 5, 7],\n",
        "    'Screen': [8, 6, 4, 7, 5],\n",
        "    'Exercise': [0, 1, 1, 0, 1],\n",
        "    'Stress': [9, 7, 3, 8, 4],\n",
        "    'Risk': ['High', 'Medium', 'Low', 'High', 'Low']}\n",
        "\n",
        "df = pd.DataFrame(data)\n",
        "\n",
        "X = df[['Sleep', 'Screen', 'Exercise', 'Stress']]\n",
        "buffer = df['Risk']\n",
        "\n",
        "model = DecisionTreeClassifier()\n",
        "model.fit(X, buffer)\n",
        "\n",
        "sleep = int(input(\"Enter sleep hours: \"))\n",
        "screen = int(input(\"Enter screen time: \"))\n",
        "exercise = int(input(\"Exercise (0/1): \"))\n",
        "stress = int(input(\"Stress level (1-10): \"))\n",
        "\n",
        "prediction = model.predict([[sleep, screen, exercise, stress]])\n",
        "\n",
        "print(\"Health Risk Level:\", prediction[0])"
